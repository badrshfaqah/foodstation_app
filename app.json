{
  "expo": {
    "name": "فودستيشن",
    "slug": "foodstation-app",
    "version": "1.8.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "foodstationapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "sa.foodstation.app",
      "buildNumber": "10",
      "supportsTablet": false,
      "infoPlist": {
        "NSFaceIDUsageDescription": "نستخدم Face ID لفتح التطبيق بسرعة بدل إدخال رمز التحقق في كل مرة."
      }
    },
    "android": {
      "package": "sa.foodstation.app",
      "versionCode": 10,
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#E8490F",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 160
        }
      ],
      "expo-secure-store",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "نحتاج الوصول إلى صورك لاختيار ورفع إيصال التحويل البنكي.",
          "cameraPermission": false
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/android-icon-foreground.png",
          "color": "#E8490F"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
